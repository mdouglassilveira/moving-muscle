# Copy to .env and fill in.
# Production secrets are configured in Deno Deploy dashboard (not committed).

# Supabase
SUPABASE_CONNECTION_STRING=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps (customer-portal)
GOOGLE_MAPS_API_KEY=

# Coassemble
COASSEMBLE_BASE_URL=https://learn.movingmuscle.co/api/v1
COASSEMBLE_USER_ID=
COASSEMBLE_API_TOKEN=
COASSEMBLE_COURSE_ID=141019

# Twilio (onboard-mover)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Moving Muscle <help@getmovingmuscle.com>

# Webhook auth — generate with `openssl rand -hex 32`
WEBHOOK_SECRET=
